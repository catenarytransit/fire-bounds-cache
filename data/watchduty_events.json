				"data": {
					"geo_event_type": "location",
					"location_type": "evac_shelter",
					"information": "<p>An evacuation shelter is set up at Fulton Convention Center located at 402 N Fulton Beach Rd, Fulton, TX 78358, per <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://www.facebook.com/permalink.php?story_fbid=pfbid02nW4KEPKV3N829yYouuVXromo3mSThw8HQwzxvXjxjAW1DYYt2nJJupszYXGLEKNvl&amp;id=100064902151572\">Rockport Public Safety Communications</a>. Red Cross is on site with food and water. Pets can also be brought to the evacuation shelter.</p>",
					"links": []
				}
			},
			{
				"id": 45514,
				"address": "872 Airport Rd, Rockport, TX 78382, USA",
				"name": "Animal Shelter - Aransas County Animal Care Services",
